---
import Layout from '../layouts/Layout.astro'
import { fetchTestimonials, fetchBlogPosts } from '../sanity/client'

let testimonials: any[] = []
let blogPosts: any[] = []

try {
  [testimonials, blogPosts] = await Promise.all([
    fetchTestimonials(),
    fetchBlogPosts(),
  ])
} catch (e) {
  // Sanity未接続時はフォールバックを使用
}

const defaultTestimonials = [
  { name: 'K.M. 様', profile: '50代・大阪市在住', area: '神戸市北区の実家 / 遺品整理 3LDK', rating: 5, content: '「母が亡くなり、神戸に残した実家の遺品整理をお願いしました。私は大阪在住で立ち会えなかったのですが、作業中の写真をこまめにLINEで送ってくれて、本当に安心できました。遺品も丁寧に扱っていただき、感謝しかありません。」' },
  { name: 'T.Y. 様', profile: '48歳・神戸市垂水区', area: '神戸市長田区 / ゴミ屋敷清掃 一戸建て', rating: 5, content: '「父の家がゴミ屋敷状態になっていて、どこに頼めばいいかわからず途方に暮れていました。電話したら翌日すぐに来ていただき、嫌な顔一つせず作業してくれました。見積り通りの金額で安心しました。」' },
  { name: 'S.N. 様', profile: '53歳・兵庫県三田市', area: '神戸市灘区 / 遺品整理 2LDK＋買取', rating: 5, content: '「仏壇や着物、貴金属など価値があるかわからないものがたくさんありましたが、丁寧に査定していただき、買取金額をそのまま作業費から引いてくれました。思ったより安くなり驚きました。」' },
  { name: 'H.F. 様', profile: '45歳・神戸市須磨区', area: '神戸市須磨区 / 生前整理 1LDK', rating: 5, content: '「急に明け渡しの期限が決まり、2日後に来てもらえるか問い合わせたら、翌日に対応していただけました。坂の多い須磨の住宅地でも問題なく作業してもらえて、本当に助かりました。」' },
]

const defaultBlogPosts = [
  { slug: { current: '#' }, publishedAt: '2026-03-01', title: '三宮でおすすめの遺品整理業者5選【2026年最新】', category: 'area-guide', excerpt: '三宮エリアで実績のある遺品整理業者を徹底比較。料金・対応エリア・資格・口コミを元にランキング形式でご紹介します。' },
  { slug: { current: '#' }, publishedAt: '2026-02-15', title: '神戸市のゴミ屋敷清掃にかかる費用の相場と業者選びのポイント', category: 'gomiyashiki', excerpt: 'ゴミ屋敷清掃の費用相場は間取りや荷物量によって大きく異なります。神戸市内の事例を元に、適正価格の見極め方を解説します。' },
  { slug: { current: '#' }, publishedAt: '2026-02-01', title: '遺品整理士とはどんな資格？神戸で依頼するメリットを解説', category: 'isan-seiri', excerpt: '「遺品整理士」という認定資格をご存知ですか？資格の内容、取得方法、メリットをわかりやすく解説します。' },
]

const displayTestimonials = testimonials.length > 0 ? testimonials : defaultTestimonials
const displayBlogPosts = blogPosts.length > 0 ? blogPosts : defaultBlogPosts

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "神戸お片付けサポートセンター",
  "description": "神戸市全9区対応の遺品整理・ゴミ屋敷清掃・生前整理・特殊清掃の専門業者。遺品整理士在籍。最短即日対応。",
  "url": "https://kobe-kataduke-support.jp/",
  "telephone": "LINEで無料相談",
  "priceRange": "¥¥",
  "openingHours": "Mo-Su 00:00-24:00",
  "areaServed": [
    { "@type": "City", "name": "神戸市東灘区" },
    { "@type": "City", "name": "神戸市灘区" },
    { "@type": "City", "name": "神戸市中央区" },
    { "@type": "City", "name": "神戸市兵庫区" },
    { "@type": "City", "name": "神戸市北区" },
    { "@type": "City", "name": "神戸市長田区" },
    { "@type": "City", "name": "神戸市須磨区" },
    { "@type": "City", "name": "神戸市垂水区" },
    { "@type": "City", "name": "神戸市西区" },
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "遺品整理・ゴミ屋敷清掃サービス",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "遺品整理" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "生前整理" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ゴミ屋敷清掃" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "特殊清掃" } },
    ],
  },
}

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "見積もり後の追加料金は本当にないですか？", "acceptedAnswer": { "@type": "Answer", "text": "はい、絶対にありません。事前にお部屋の状況をしっかり確認し、すべての作業内容・処分費用を含めた「完全コミコミ価格」でお見積りします。" } },
    { "@type": "Question", "name": "遠方に住んでいて立ち会えませんが、依頼可能ですか？", "acceptedAnswer": { "@type": "Answer", "text": "もちろん可能です。作業前・中・後の写真・動画をLINEやメールでリアルタイムにご報告しますので、遠方の方でも安心してお任せいただけます。" } },
    { "@type": "Question", "name": "足の踏み場もないゴミ屋敷ですが、そのままの状態で大丈夫ですか？", "acceptedAnswer": { "@type": "Answer", "text": "大丈夫です。むしろそのような状況でのご依頼が最も多く、ゴミ屋敷清掃のプロとして豊富な実績がございます。秘密は厳守します。" } },
  ],
}

const categoryLabels: Record<string, string> = {
  'isan-seiri': '遺品整理',
  'seizen-seiri': '生前整理',
  'gomiyashiki': 'ゴミ屋敷清掃',
  'tokusu-seiou': '特殊清掃',
  'area-guide': '地域ガイド',
  'tips': 'お役立ち情報',
}
---

<Layout
  title="神戸市の遺品整理・ゴミ屋敷清掃なら【神戸お片付けサポートセンター】即日対応・無料見積り"
  description="神戸市全9区対応。遺品整理・生前整理・ゴミ屋敷清掃は神戸お片付けサポートセンターへ。遺品整理士在籍、最短即日対応、お見積り後の追加費用一切なし。"
  schema={[localBusinessSchema, faqSchema]}
>

<!-- HEADER -->
<header class="bg-[#081a38] sticky top-0 z-50 shadow-lg">
  <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between gap-2">
    <div class="flex flex-col leading-tight">
      <span class="text-[#f5c842] font-black text-lg md:text-xl tracking-tight">神戸お片付けサポートセンター</span>
      <span class="text-blue-200 text-xs mt-0.5">遺品整理・ゴミ屋敷清掃の専門窓口</span>
    </div>
    <div class="flex flex-col items-end gap-1">
      <span class="text-green-400 text-xs font-bold tracking-wide">✅ 24時間受付・年中無休</span>
      <a href="https://line.me/R/ti/p/@622cifkz" target="_blank" rel="noopener" class="cta-btn tel-link text-sm md:text-base px-5 py-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5.5a15.5 15.5 0 0015 15l2.5-2.5-3-3-2 2a11 11 0 01-7-7l2-2-3-3L3 5.5z"/></svg>
        <span class="font-black">LINEで無料相談</span>
      </a>
    </div>
  </div>
</header>

<!-- HERO -->
<section class="relative overflow-hidden bg-[#081a38] text-white" aria-label="ファーストビュー">
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1200&auto=format&fit=crop&q=60" alt="整理されたリビング" class="w-full h-full object-cover opacity-20" loading="eager"/>
    <div class="absolute inset-0 bg-gradient-to-b from-[#081a38]/80 via-[#081a38]/60 to-[#081a38]/90"></div>
  </div>
  <div class="relative max-w-3xl mx-auto px-5 py-14 md:py-20 text-center">
    <div class="inline-block bg-[#e8a900] text-[#081a38] text-xs font-black px-4 py-1.5 rounded-full mb-5 tracking-widest shadow">神戸市全9区 最短即日対応</div>
    <h1 class="text-2xl md:text-4xl font-black leading-snug mb-4 drop-shadow-md">
      神戸市のご実家のお片付け、遺品整理。<br class="hidden md:block"/>
      <span class="text-[#f5c842]">ご遺族に寄り添い、</span>最短即日で解決します。
    </h1>
    <p class="text-blue-100 text-sm md:text-base mb-7 leading-relaxed">
      <span class="bg-white/15 rounded px-2 py-0.5 mr-2">お見積り後の追加費用一切なし</span>
      <span class="bg-white/15 rounded px-2 py-0.5 mr-2">秘密厳守</span>
      <span class="bg-white/15 rounded px-2 py-0.5">立ち会い不要も可</span>
    </p>
    <div class="flex flex-col items-center gap-3">
      <a href="https://line.me/R/ti/p/@622cifkz" target="_blank" rel="noopener" class="cta-btn tel-link relative pulse-ring w-full max-w-sm text-xl md:text-2xl py-5 px-8 shadow-2xl">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5.5a15.5 15.5 0 0015 15l2.5-2.5-3-3-2 2a11 11 0 01-7-7l2-2-3-3L3 5.5z"/></svg>
        <span>LINEで無料見積りを依頼</span>
      </a>
      <span class="text-blue-200 text-sm">💬 LINEで24時間・年中無休受付</span>
    </div>
    <div class="mt-8 grid grid-cols-3 gap-3 text-center text-xs text-blue-200">
      <div class="bg-white/10 rounded-xl py-3 px-2"><div class="text-[#f5c842] text-xl font-black">1,200<span class="text-base">件以上</span></div><div>神戸市内実績</div></div>
      <div class="bg-white/10 rounded-xl py-3 px-2"><div class="text-[#f5c842] text-xl font-black">4.9<span class="text-base">★</span></div><div>お客様満足度</div></div>
      <div class="bg-white/10 rounded-xl py-3 px-2"><div class="text-[#f5c842] text-xl font-black">最短<span class="text-base">即日</span></div><div>駆けつけ対応</div></div>
    </div>
  </div>
</section>
<div class="section-divider"></div>

<!-- PAIN POINTS -->
<section class="bg-slate-50 py-12 px-5" aria-labelledby="pain-heading">
  <div class="max-w-3xl mx-auto">
    <p class="text-center text-xs font-bold tracking-widest text-[#1a4480] mb-2 uppercase">こんなお悩みありませんか？</p>
    <h2 id="pain-heading" class="text-xl md:text-2xl font-black text-center text-[#081a38] mb-8">「急いで片付けたい…でも、どうすれば」<br/>と途方に暮れているあなたへ</h2>
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {[
        { icon: '😞', title: '他府県に住んでいて、実家に行けない', desc: '仕事や家族の都合で現地に行けず、実家の状況が気になって仕方ない…' },
        { icon: '😰', title: 'ゴミ屋敷化してご近所の目が気になる', desc: '親が亡くなり数ヶ月…家の状態が悪化しご近所さんに申し訳ない気持ちが…' },
        { icon: '💸', title: '業者に頼んだら高額請求されそうで怖い', desc: 'ニュースで見るような後から追加料金の請求が怖くて、一歩踏み出せない…' },
        { icon: '🏔️', title: '坂道・細路地で大型トラックが入れない', desc: '灘区や北区など神戸特有の地形で、対応できる業者がなかなか見つからない…' },
        { icon: '⏰', title: '家の売却・明け渡しまで時間がない', desc: '不動産会社から期限を告げられ、早急に片付けなければならない状況…' },
        { icon: '💔', title: '大切な遺品を粗末に扱われたくない', desc: '故人の思い出の品々を、ただのゴミとして処分されてしまいそうで不安…' },
      ].map(p => (
        <li class="bg-white rounded-2xl p-5 shadow-sm border-l-4 border-red-400 flex gap-3">
          <span class="text-red-400 text-2xl mt-0.5 flex-shrink-0">{p.icon}</span>
          <div><p class="font-bold text-[#081a38] mb-1">{p.title}</p><p class="text-gray-500 text-sm">{p.desc}</p></div>
        </li>
      ))}
    </ul>
    <div class="mt-8 bg-[#081a38] text-white rounded-2xl p-6 text-center">
      <p class="font-black text-lg md:text-xl mb-3">そのお悩み、すべて<span class="text-[#f5c842]">解決できます。</span></p>
      <p class="text-blue-100 text-sm mb-5">神戸市で10年以上。地元を熟知した専門スタッフが、あなたの状況に合わせて柔軟に対応します。</p>
      <a href="https://line.me/R/ti/p/@622cifkz" target="_blank" rel="noopener" class="cta-btn tel-link text-base md:text-lg px-8 py-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5.5a15.5 15.5 0 0015 15l2.5-2.5-3-3-2 2a11 11 0 01-7-7l2-2-3-3L3 5.5z"/></svg>
        💬 LINEで今すぐ無料相談
      </a>
    </div>
  </div>
</section>
<div class="section-divider"></div>

<!-- TESTIMONIALS -->
<section class="bg-white py-12 px-5" aria-labelledby="testimonials-heading">
  <div class="max-w-3xl mx-auto">
    <p class="text-center text-xs font-bold tracking-widest text-[#1a4480] mb-2 uppercase">お客様の声</p>
    <h2 id="testimonials-heading" class="text-xl md:text-2xl font-black text-center text-[#081a38] mb-2">実際にご依頼いただいた<span class="text-[#c98700]">お客様の声</span></h2>
    <p class="text-center text-gray-500 text-sm mb-8">神戸市内のご依頼者様から寄せられた感想の一部をご紹介します。</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {displayTestimonials.slice(0, 4).map((t: any) => (
        <article class="bg-slate-50 rounded-2xl p-5 border border-slate-100 shadow-sm">
          <div class="flex items-center gap-1 text-[#e8a900] text-base mb-2">{'★'.repeat(t.rating || 5)}</div>
          <p class="text-gray-700 text-sm leading-relaxed mb-4">{t.content}</p>
          <div class="flex items-center gap-3">
            <div class="bg-[#b3c7e9] rounded-full w-10 h-10 flex items-center justify-center text-[#1a4480] font-black text-sm flex-shrink-0">{t.name?.charAt(0) || 'K'}</div>
            <div>
              <p class="font-bold text-[#081a38] text-sm">{t.name}</p>
              <p class="text-gray-400 text-xs">{t.area || t.profile}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
    <div class="mt-8 bg-[#081a38] rounded-2xl p-5 flex flex-col sm:flex-row items-center justify-center gap-4 text-white text-center">
      <div>
        <p class="text-5xl font-black text-[#f5c842]">4.9</p>
        <div class="text-[#f5c842] text-xl mt-1">★★★★★</div>
        <p class="text-blue-200 text-xs mt-1">総合評価</p>
      </div>
      <div class="w-px h-16 bg-white/20 hidden sm:block"></div>
      <div class="text-sm text-blue-100 leading-relaxed">
        <p class="font-black text-white text-base mb-1">神戸市内で1,200件以上の実績</p>
        <p>ご依頼いただいたお客様の<span class="text-[#f5c842] font-bold">96%</span>が<br/>「また頼みたい」と回答されています。</p>
      </div>
    </div>
  </div>
</section>
<div class="section-divider"></div>

<!-- WHY CHOOSE US -->
<section class="bg-white py-12 px-5" aria-labelledby="why-heading">
  <div class="max-w-3xl mx-auto">
    <p class="text-center text-xs font-bold tracking-widest text-[#1a4480] mb-2 uppercase">選ばれる理由</p>
    <h2 id="why-heading" class="text-xl md:text-2xl font-black text-center text-[#081a38] mb-8">神戸市1,200件以上の実績。<br/>私たちが選ばれる<span class="text-[#e8a900]">3つの理由</span></h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        { emoji: '🚚', title: '①神戸密着・即日対応', desc: '北区・西区のニュータウンから灘区・兵庫区の細い坂道まで、神戸の地形を知り尽くしたスタッフが対応。電話当日の作業開始も可能です。' },
        { emoji: '🏅', title: '②遺品整理士在籍・供養も', desc: '資格を持つ「遺品整理士」が在籍。大切なお品物を丁寧に仕分けし、ご希望に応じて提携寺院でのお焚き上げ・供養も承ります。' },
        { emoji: '💴', title: '③明朗パック料金・買取相殺', desc: 'わかりやすい間取り別パック料金で追加費用ゼロ。家電・貴金属・着物など価値あるお品は査定・買取を行い、費用から差し引きます。' },
      ].map(r => (
        <article class="bg-[#f0f4fa] rounded-2xl p-6 text-center flex flex-col items-center">
          <div class="bg-[#0f2d5c] text-[#f5c842] rounded-full w-14 h-14 flex items-center justify-center text-2xl mb-4 shadow">{r.emoji}</div>
          <h3 class="font-black text-[#081a38] text-base mb-2">{r.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{r.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
<div class="section-divider"></div>

<!-- SERVICES -->
<section class="bg-[#081a38] text-white py-12 px-5" aria-labelledby="services-heading">
  <div class="max-w-3xl mx-auto">
    <p class="text-center text-xs font-bold tracking-widest text-[#f5c842] mb-2 uppercase">サービス内容</p>
    <h2 id="services-heading" class="text-xl md:text-2xl font-black text-center mb-8">お片付けのことなら、<br/>どんなことでもお任せください</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {[
        { emoji: '🕯️', title: '遺品整理', desc: '故人が残された家財・衣類・書類などを、ご遺族の意向を確認しながら丁寧に仕分け・搬出。形見分け品の仕分け補助や、供養のご手配も承ります。' },
        { emoji: '🌸', title: '生前整理', desc: '元気なうちに自分の持ち物を整理しておきたい方へ。残したいものと手放すものを一緒に仕分けし、ご家族への負担を軽減します。' },
        { emoji: '🏠', title: 'ゴミ屋敷清掃', desc: '床一面にゴミが積み上がったような状態でも対応可。搬出・清掃・消臭・除菌まで一括で行い、元の生活空間に戻します。' },
        { emoji: '🔬', title: '特殊清掃', desc: '孤独死・事故死・腐敗など、通常の清掃では対処できない現場も可能。専用機材と薬剤を使用し、臭気の完全除去と消毒・処理を行います。' },
      ].map(s => (
        <article class="bg-white/10 backdrop-blur rounded-2xl p-6 border border-white/20 hover:bg-white/15 transition-colors">
          <div class="text-3xl mb-3">{s.emoji}</div>
          <h3 class="font-black text-[#f5c842] text-lg mb-2">{s.title}</h3>
          <p class="text-blue-100 text-sm leading-relaxed">{s.desc}</p>
        </article>
      ))}
    </div>
    <div class="mt-8 text-center">
      <a href="https://line.me/R/ti/p/@622cifkz" target="_blank" rel="noopener" class="cta-btn tel-link text-lg px-10 py-4 mx-auto">
