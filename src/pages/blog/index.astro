---
import Layout from '../../layouts/Layout.astro'
import { fetchBlogPosts } from '../../sanity/client'

let posts: any[] = []
try {
  posts = await fetchBlogPosts()
} catch (e) {}

const fallback = [
  { slug: { current: 'sanbu-isan-seiri-5sen' }, publishedAt: '2026-03-01', title: '三宮でおすすめの遺品整理業者5選【2026年最新】', category: 'area-guide', excerpt: '三宮エリアで実績のある遺品整理業者を徹底比較。料金・対応エリア・資格・口コミを元にランキング形式でご紹介します。' },
  { slug: { current: 'gomiyashiki-cost-kobe' }, publishedAt: '2026-02-15', title: '神戸市のゴミ屋敷清掃にかかる費用の相場と業者選びのポイント', category: 'gomiyashiki', excerpt: 'ゴミ屋敷清掃の費用相場は間取りや荷物量によって大きく異なります。神戸市内の事例を元に、適正価格の見極め方を解説します。' },
  { slug: { current: 'isan-seiri-shi-kobe' }, publishedAt: '2026-02-01', title: '遺品整理士とはどんな資格？神戸で依頼するメリットを解説', category: 'isan-seiri', excerpt: '「遺品整理士」という認定資格をご存知ですか？資格の内容、取得方法、メリットをわかりやすく解説します。' },
]

const displayPosts = posts.length > 0 ? posts : fallback

const categoryLabels: Record<string, string> = {
  'isan-seiri': '遺品整理',
  'seizen-seiri': '生前整理',
  'gomiyashiki': 'ゴミ屋敷清掃',
  'tokusu-seiou': '特殊清掃',
  'area-guide': '地域ガイド',
  'tips': 'お役立ち情報',
}
---

<Layout
  title="お役立ち記事一覧 | 神戸お片付けサポートセンター"
  description="神戸市の遺品整理・ゴミ屋敷清掃に関するお役立ち情報を発信しています。費用の目安、業者選びのコツ、地域別ガイドなど。"
>

<header class="bg-[#081a38] sticky top-0 z-50 shadow-lg">
  <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between gap-2">
    <a href="/" class="flex flex-col leading-tight">
      <span class="text-[#f5c842] font-black text-lg tracking-tight">神戸お片付けサポートセンター</span>
      <span class="text-blue-200 text-xs mt-0.5">遺品整理・ゴミ屋敷清掃の専門窓口</span>
    </a>
    <a href="tel:050XXXXXXXX" class="cta-btn tel-link text-sm px-5 py-2.5">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5.5a15.5 15.5 0 0015 15l2.5-2.5-3-3-2 2a11 11 0 01-7-7l2-2-3-3L3 5.5z"/></svg>
      <span class="font-black">050-XXXX-XXXX</span>
    </a>
  </div>
</header>

<main class="min-h-screen bg-slate-50 py-12 px-5">
  <div class="max-w-3xl mx-auto">
    <nav class="text-xs text-gray-400 mb-6">
      <a href="/" class="hover:text-[#1a4480]">トップ</a> &rsaquo; お役立ち記事
    </nav>

    <p class="text-center text-xs font-bold tracking-widest text-[#1a4480] mb-2 uppercase">お役立ち情報</p>
    <h1 class="text-2xl md:text-3xl font-black text-center text-[#081a38] mb-10">
      遺品整理・ゴミ屋敷清掃の<br/><span class="text-[#c98700]">お役立ち記事</span>
    </h1>

    <div class="grid grid-cols-1 gap-6">
      {displayPosts.map((post: any) => (
        <a href={`/blog/${post.slug?.current}`} class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition-shadow block group">
          <div class="flex items-start gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-block bg-[#0f2d5c] text-[#f5c842] text-xs px-3 py-1 rounded-full font-bold">{categoryLabels[post.category] || 'お役立ち情報'}</span>
                <time class="text-gray-400 text-xs">{post.publishedAt?.replace(/-/g, '.')}</time>
              </div>
              <h2 class="font-black text-[#081a38] text-base md:text-lg leading-snug mb-2 group-hover:text-[#2d5fa0] transition-colors">{post.title}</h2>
              <p class="text-gray-500 text-sm leading-relaxed">{post.excerpt}</p>
            </div>
            <span class="text-[#2d5fa0] font-bold text-sm flex-shrink-0 mt-1">→</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12 bg-[#081a38] text-white rounded-2xl p-6 text-center">
      <p class="font-black text-lg mb-2">まずはお気軽にご相談ください</p>
      <p class="text-blue-200 text-sm mb-4">24時間・年中無休で受付中です</p>
      <a href="tel:050XXXXXXXX" class="cta-btn tel-link text-lg px-8 py-4 mx-auto">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5.5a15.5 15.5 0 0015 15l2.5-2.5-3-3-2 2a11 11 0 01-7-7l2-2-3-3L3 5.5z"/></svg>
        無料見積りに電話する
      </a>
    </div>
  </div>
</main>

</Layout>
